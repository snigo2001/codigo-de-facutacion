import tkinter as tk
from tkinter import messagebox
from reportlab.platypus import SimpleDocTemplate, Paragraph, Spacer
from reportlab.lib.styles import getSampleStyleSheet
import os
from datetime import datetime


BASE_PDF_DIR = r"C:\Users\snigo\OneDrive\Documentos\factura de salud\factura_pdf"

os.makedirs(BASE_PDF_DIR, exist_ok=True)


def generar_pdf(cliente, productos):
    fecha_actual = datetime.now()
    factura_id = fecha_actual.strftime("%Y%m%d%H%M%S")

    ruta_fecha = os.path.join(
        BASE_PDF_DIR,
        str(fecha_actual.year),
        str(fecha_actual.month)
    )

    os.makedirs(ruta_fecha, exist_ok=True)

    archivo = os.path.join(ruta_fecha, f"factura_{factura_id}.pdf")

    doc = SimpleDocTemplate(archivo)
    estilos = getSampleStyleSheet()
    contenido = []

    contenido.append(Paragraph("FACTURA", estilos['Title']))
    contenido.append(Spacer(1, 10))
    contenido.append(Paragraph(f"Cliente: {cliente}", estilos['Normal']))
    contenido.append(Paragraph(f"Fecha: {fecha_actual}", estilos['Normal']))
    contenido.append(Spacer(1, 10))

    subtotal = 0

    for p in productos:
        linea = f"{p['nombre']} - {p['cantidad']} x {p['precio']}"
        contenido.append(Paragraph(linea, estilos['Normal']))
        subtotal += p['cantidad'] * p['precio']

    iva = subtotal * 0.19
    total = subtotal + iva

    contenido.append(Spacer(1, 10))
    contenido.append(Paragraph(f"Subtotal: {subtotal}", estilos['Normal']))
    contenido.append(Paragraph(f"IVA: {iva}", estilos['Normal']))
    contenido.append(Paragraph(f"Total: {total}", estilos['Normal']))

    doc.build(contenido)

    return archivo


def crear_factura():
    ventana = tk.Toplevel()
    ventana.title("Nueva Factura")
    ventana.geometry("400x500")

    productos = []

    tk.Label(ventana, text="Cliente").grid(row=0, column=0)
    cliente_entry = tk.Entry(ventana)
    cliente_entry.grid(row=0, column=1)

    tk.Label(ventana, text="Producto").grid(row=1, column=0)
    nombre_entry = tk.Entry(ventana)
    nombre_entry.grid(row=1, column=1)

    tk.Label(ventana, text="Precio").grid(row=2, column=0)
    precio_entry = tk.Entry(ventana)
    precio_entry.grid(row=2, column=1)

    tk.Label(ventana, text="Cantidad").grid(row=3, column=0)
    cantidad_entry = tk.Entry(ventana)
    cantidad_entry.grid(row=3, column=1)

    lista = tk.Listbox(ventana, width=50)
    lista.grid(row=5, column=0, columnspan=2)

    def agregar_producto():
        nombre = nombre_entry.get()
        precio = precio_entry.get()
        cantidad = cantidad_entry.get()

        if not nombre or not precio or not cantidad:
            messagebox.showerror("Error", "Complete todos los campos")
            return

        try:
            precio = float(precio)
            cantidad = float(cantidad)
        except:
            messagebox.showerror("Error", "Datos inválidos")
            return

        productos.append({
            "nombre": nombre,
            "precio": precio,
            "cantidad": cantidad
        })

        lista.insert(tk.END, f"{nombre} - {cantidad} x {precio}")

        nombre_entry.delete(0, tk.END)
        precio_entry.delete(0, tk.END)
        cantidad_entry.delete(0, tk.END)

    def generar():
        cliente = cliente_entry.get()

        if not cliente:
            messagebox.showerror("Error", "Ingrese el cliente")
            return

        if not productos:
            messagebox.showerror("Error", "Agregue productos")
            return

        archivo = generar_pdf(cliente, productos)

        messagebox.showinfo("Éxito", "Factura generada")

        os.startfile(archivo)

        ventana.destroy()

    tk.Button(ventana, text="Agregar Producto", command=agregar_producto)\
        .grid(row=4, column=0, columnspan=2)

    tk.Button(ventana, text="Generar Factura", command=generar)\
        .grid(row=6, column=0, columnspan=2)



app = tk.Tk()
app.title("Sistema de Facturación")
app.geometry("300x200")

tk.Label(app, text="Sistema de Facturación").pack(pady=10)

tk.Button(app, text="Nueva Factura", command=crear_factura).pack(pady=5)
tk.Button(app, text="Salir", command=app.quit).pack(pady=5)

app.mainloop()
